{
  "manifest_version": 3,
  "name": "Jp-word2txt",
  "version": "1.0",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "activeTab",
    "tabs",
    "downloads",
    "scripting"
  ],

  "host_permissions": [
    "https://learn.dict.naver.com/*",
    "https://ja.dict.naver.com/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://learn.dict.naver.com/*",
        "https://ja.dict.naver.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],

   "commands": {
    "save-word": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "현재 단어 저장"
    }
  },

  "background": {
    "service_worker": "background.js"
  }
}